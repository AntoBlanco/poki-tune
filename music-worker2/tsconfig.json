{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // Configuración para Node
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}