  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "ioredis": "^5.10.0"
  }
}